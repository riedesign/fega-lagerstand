; Kopiere diese Datei nach `.env` und trage echte Werte ein.
; .env ist via .gitignore ausgeschlossen.

; ─── Datenbank ────────────────────────────────────────────────
DB_SERVER=192.168.10.144
DB_USERNAME=teci_viewonly
DB_PASSWORD=
DB_NAME=crone_log

; ─── Laufzeit ────────────────────────────────────────────────
; Setze APP_ENV=production in Produktion, um display_errors zu
; deaktivieren. Dev/local = development.
APP_ENV=production

; ─── Auth (optional, falls JWT-Cookie-Check aktiviert wird) ──
; Identisch mit dem Wert im Rieste-Auth-Portal.
JWT_SECRET_KEY=
