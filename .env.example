; Kopiere diese Datei nach `.env` und trage echte Werte ein.
; .env ist via .gitignore ausgeschlossen.

; ─── Datenbank (Fega / crone_log) ─────────────────────────────
DB_SERVER=192.168.10.144
DB_USERNAME=teci_viewonly
DB_PASSWORD=
DB_NAME=crone_log

; ─── Laufzeit ────────────────────────────────────────────────
; Setze APP_ENV=production in Produktion, um display_errors zu
; deaktivieren. Dev/local = development.
APP_ENV=production

; ─── Auth (JWT-Cookie vom Rieste-Auth-Portal) ────────────────
; Identisch mit dem Wert im Rieste-Auth-Portal.
JWT_SECRET_KEY=

; ─── JTL MS SQL (optional, fuer Rieste-Bestand in der Dispo-Seite) ──
; Wenn gesetzt: Dispo-Seite zeigt zusaetzlich den aktuellen Bestand
; bei uns (Rieste) zu den Fega-Artikeln. Braucht php-sybase (pdo_dblib)
; installiert auf dem Server.
; Werte 1:1 aus Rieste-Invoicemanager/.env uebernehmen.
JTL_MSSQL_HOST=192.168.10.5
JTL_MSSQL_PORT=63151
JTL_MSSQL_USER=openclaw_readonly
JTL_MSSQL_PASSWORD=
JTL_MSSQL_DATABASE=eazybusiness
